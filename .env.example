# Copy to .env (or let `make up` create it) and adjust as needed.
# These defaults already work with docker-compose.

# Application
ENVIRONMENT=local
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_DB=exchange
POSTGRES_USER=exchange_user
POSTGRES_PASSWORD=exchange_pass
DATABASE_URL=postgresql+psycopg://exchange_user:exchange_pass@postgres:5432/exchange

# AWS / LocalStack
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
